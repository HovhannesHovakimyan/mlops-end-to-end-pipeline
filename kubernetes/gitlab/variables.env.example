# GitLab Project CI/CD Variables Template
# Copy this file, rename to variables.env, and update with your actual values
# Then pass to provisioner: ./07-project-provisioner.sh --variables-file variables.env

# Container Registry Credentials
REGISTRY_USER=myregistry_user
REGISTRY_PASSWORD=myregistry_password

# MLflow Tracking Server (for model versioning)
MLFLOW_TRACKING_URI=http://mlflow.mlflow:5000

# MinIO Object Storage (for model artifacts)
MINIO_ENDPOINT=http://minio.minio:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# Kubernetes Contexts
KUBE_CONTEXT=minikube
KUBE_CONTEXT_STAGING=minikube
